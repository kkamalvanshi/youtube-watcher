# Copy to .env for local testing:  set -a; source .env; set +a
ANTHROPIC_API_KEY=sk-ant-...
# Sending — via Resend, so mail arrives from a distinct sender (not "from me"):
RESEND_API_KEY=re_...
RESEND_FROM="YouTube Watcher <onboarding@resend.dev>"
RECIPIENT=kkamalvanshi@gmail.com
# Reading commands — Gmail IMAP (your replies route here via Reply-To):
GMAIL_ADDRESS=kkamalvanshi@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
ALLOWLIST_SENDERS=kkamalvanshi@gmail.com
# For full transcripts from cloud IPs — Webshare RESIDENTIAL proxy credentials:
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
